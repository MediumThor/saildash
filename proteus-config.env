# Proteus Configuration
# Mode: 'local' or 'online'
PROTEUS_MODE=local

# Local LLM Settings
# These are used when PROTEUS_MODE=local
LLAMA_SERVER_URL=http://127.0.0.1:3002
MODEL_NAME=llama-3.2-3b-instruct-q4_k_m.gguf
MAX_TOKENS=500
TEMPERATURE=0.7

# Online API Settings
# These are used when PROTEUS_MODE=online
# Uncomment and set your API key to use online mode
OPENAI_API_KEY=***REMOVED***
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-3.5-turbo
ONLINE_MAX_TOKENS=500
ONLINE_TEMPERATURE=0.7 